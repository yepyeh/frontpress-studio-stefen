{
    "name": "marko/frontpress-studio",
    "description": "Ultralight flat-file markdown framework",
    "type": "project",
    "require": {
        "php": ">=8.1",
        "league/commonmark": "^2.4",
        "symfony/yaml": "^6.4",
        "enshrined/svg-sanitize": "^0.22.0",
        "twig/twig": "^3.10",
        "scssphp/scssphp": "^2.1"
    },
    "autoload": {
        "psr-4": {
            "FrontPress\\": "lib/"
        }
    },
    "config": {
        "platform": {
            "php": "8.1.0"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "phpstan/phpstan": "^2.1",
        "friendsofphp/php-cs-fixer": "^3.95"
    },
    "scripts": {
        "test": "phpunit",
        "stan": "phpstan analyse --memory-limit=1G -c ../phpstan.neon",
        "lint": "php-cs-fixer check --diff",
        "format": "php-cs-fixer fix",
        "check": [
            "@test",
            "@stan",
            "@lint"
        ]
    }
}
